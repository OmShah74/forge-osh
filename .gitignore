.env
remember.md
target/
dist/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
tempp/
.claude/
todo.txt

# forge-osh user data — safety net in case a .forge-osh/ directory is
# accidentally created inside the repo root (e.g. if FORGE_CONFIG_DIR is
# set to the project dir during development).  These patterns are anchored
# to the repo root with a leading slash so they CANNOT match src/, Cargo.toml,
# or any other part of the codebase.
/.forge-osh/
/keys.json
/hooks.json
/permissions.json
test_errors.log
target-build/

# ── Node / VS Code extension build artifacts ───────────────────────────
# Apply repo-wide so any subdirectory (extensions/vscode/, tools/, etc.)
# stays safe even if its own .gitignore is missed.
node_modules/
out/
build/
.next/
.cache/
*.vsix
*.tsbuildinfo
.npm/
.yarn/
.pnpm-store/
.vscode-test/

# Per-extension bundled binaries — never commit these, the extension
# auto-discovers from osh.releaseDir (~/forge-build/release/) instead.
extensions/vscode/bin/

# ── Editor / IDE local state ───────────────────────────────────────────
.vs/
.idea/
*.iml
.history/

# ── Test / coverage artifacts ──────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Logs ───────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Local secrets (defense-in-depth on top of keys.json rule above) ────
*.pem
*.key
secrets.json